<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SicilyLinesResa.ReservationPage"
             Shell.BackgroundColor="DeepSkyBlue"
             Shell.TitleColor="White"
             Title="Reservation">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Profil" x:Name="Profil" Clicked="Profil_Clicked">
            <ToolbarItem.IconImageSource>
                <FontImageSource FontFamily="MaterialIconsRegular" 
                        Glyph="&#xe853;"
                        Color="White"/>
            </ToolbarItem.IconImageSource>
        </ToolbarItem>
    </ContentPage.ToolbarItems>
    
    <VerticalStackLayout>

        <CollectionView x:Name="ReservationsListView" Margin="10">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <StackLayout Orientation="Horizontal" Padding="10">
                        <Label TextColor="White" Text="{Binding Id}" FontSize="Small" VerticalOptions="Center" Margin="10,0,0,0" />
                        <Label TextColor="White" Text="{Binding Date}" FontSize="Small" VerticalOptions="Center" Margin="10,0,0,0" />
                    </StackLayout>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </VerticalStackLayout>
    
</ContentPage>
    