<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SicilyLinesResa.CreerResa"
             Shell.BackgroundColor="DeepSkyBlue"
             Shell.TitleColor="White"
             Title="Creer une reservation">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Profil" x:Name="Profil" Clicked="Profil_Clicked">
            <ToolbarItem.IconImageSource>
                <FontImageSource FontFamily="MaterialIconsRegular" 
                        Glyph="&#xe853;"
                        Color="White"/>
            </ToolbarItem.IconImageSource>
        </ToolbarItem>
    </ContentPage.ToolbarItems>
   
    <VerticalStackLayout>
        <Label 
            Text="Welcome to .NET MAUI!"
            VerticalOptions="Center" 
            HorizontalOptions="Center" />
    </VerticalStackLayout>
</ContentPage>